#!/usr/bin/make -f

DEB_HOST_GNU_TYPE ?= $(shell dpkg-architecture -qDEB_HOST_GNU_TYPE)
DEB_HOST_MULTIARCH ?= $(shell dpkg-architecture -qDEB_HOST_MULTIARCH)
BUILDDIR := obj-$(DEB_HOST_GNU_TYPE)

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- -DCMAKE_BUILD_TYPE=Release -DDVBIPITOOLS_STATIC=ON -DCMAKE_LIBRARY_ARCHITECTURE=$(DEB_HOST_MULTIARCH) \
		-DOPENSSL_INCLUDE_DIR=/usr/include -DOPENSSL_CRYPTO_LIBRARY=/usr/lib/$(DEB_HOST_MULTIARCH)/libcrypto.a -DOPENSSL_SSL_LIBRARY=/usr/lib/$(DEB_HOST_MULTIARCH)/libssl.a

override_dh_auto_install:
	install -D -m 0755 $(BUILDDIR)/src/dipirec/dipirec debian/dvbipitools/usr/bin/dipirec
	install -D -m 0755 $(BUILDDIR)/src/dipiscan/dipiscan debian/dvbipitools/usr/bin/dipiscan
	install -D -m 0755 $(BUILDDIR)/src/dipiradiohead/dipiradiohead debian/dvbipitools/usr/bin/dipiradiohead
	install -D -m 0755 $(BUILDDIR)/src/dipisds/dipisds debian/dvbipitools/usr/bin/dipisds
	install -D -m 0755 $(BUILDDIR)/src/dipixmltv/dipixmltv debian/dvbipitools/usr/bin/dipixmltv
	install -D -m 0755 $(BUILDDIR)/src/dipibim/dipibim debian/dvbipitools/usr/bin/dipibim
	install -D -m 0755 $(BUILDDIR)/src/dipiepg/dipiepg debian/dvbipitools/usr/bin/dipiepg
